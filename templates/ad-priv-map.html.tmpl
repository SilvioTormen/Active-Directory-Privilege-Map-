<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="utf-8">
<title>AD Privilege Map - __DOMAIN__</title>
<script src="https://unpkg.com/vis-network/standalone/umd/vis-network.min.js"></script>
<style>
  html, body { margin:0; padding:0; height:100%; font-family:'Segoe UI',Tahoma,sans-serif; }
  #header { padding:10px 20px; background:#1f2937; color:#fff; display:flex; align-items:center; justify-content:space-between; }
  #header h1 { font-size:16px; margin:0; }
  #header .meta { font-size:12px; opacity:0.7; }
  #toolbar { padding:8px 20px; background:#f3f4f6; border-bottom:1px solid #d1d5db; display:flex; flex-wrap:wrap; gap:16px; align-items:center; font-size:13px; }
  #toolbar label { display:flex; align-items:center; gap:4px; cursor:pointer; user-select:none; }
  #toolbar select, #toolbar input[type='text'], #toolbar input[type='number'] { padding:4px 6px; font-size:13px; }
  #toolbar .grp { display:flex; gap:12px; align-items:center; }
  #toolbar .grp + .grp { border-left:1px solid #d1d5db; padding-left:16px; }
  #network { width:100%; height:calc(100vh - 130px); background:#fafafa; }
  .legend { position:absolute; top:140px; right:20px; background:#fff; padding:10px 14px; border:1px solid #ddd; border-radius:6px; font-size:12px; box-shadow:0 2px 8px rgba(0,0,0,0.08); z-index:10; max-width:300px; }
  .legend div { margin:4px 0; }
  .legend .hint { margin-top:8px; padding-top:8px; border-top:1px solid #eee; color:#555; font-size:11px; line-height:1.4; }
  .swatch { display:inline-block; width:14px; height:14px; margin-right:8px; border-radius:3px; vertical-align:middle; }
  #stats { position:absolute; bottom:10px; left:20px; background:#fff; padding:6px 10px; border:1px solid #ddd; border-radius:4px; font-size:11px; box-shadow:0 1px 4px rgba(0,0,0,0.08); z-index:10; }
  #loading { position:fixed; top:130px; left:0; right:0; bottom:0; background:rgba(255,255,255,0.95); display:flex; align-items:center; justify-content:center; flex-direction:column; z-index:100; font-size:14px; color:#1f2937; }
  #loading progress { width:300px; height:14px; margin:10px 0; }
  #loading-text { font-size:12px; color:#6b7280; margin-top:4px; }
  #paths-panel { position:absolute; top:140px; left:20px; background:#fff; border:1px solid #ddd; border-radius:6px; font-size:12px; box-shadow:0 2px 8px rgba(0,0,0,0.08); z-index:10; width:330px; max-height:calc(100vh - 170px); display:flex; flex-direction:column; }
  #paths-panel.hidden { display:none; }
  #paths-panel .head { padding:8px 12px; background:#f3f4f6; border-bottom:1px solid #d1d5db; border-radius:6px 6px 0 0; display:flex; justify-content:space-between; align-items:center; font-weight:600; }
  #paths-panel .head button { background:transparent; border:none; cursor:pointer; font-size:14px; color:#6b7280; }
  #paths-panel .body { overflow-y:auto; padding:6px 0; }
  #paths-panel .row { padding:6px 12px; cursor:pointer; border-bottom:1px solid #f3f4f6; display:flex; justify-content:space-between; gap:8px; }
  #paths-panel .row:hover { background:#fef3c7; }
  #paths-panel .row .lbl { flex:1; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  #paths-panel .row .lbl .type { font-size:10px; color:#6b7280; margin-left:4px; }
  #paths-panel .row .dist { font-weight:600; color:#dc2626; flex:0 0 auto; }
  #paths-panel .row .dist[data-d="1"] { color:#dc2626; }
  #paths-panel .row .dist[data-d="2"] { color:#ea580c; }
  #paths-panel .row .dist[data-d="3"] { color:#ca8a04; }
  #paths-panel .row .dist[data-d="4"] { color:#65a30d; }
  #paths-panel .empty { padding:12px; color:#6b7280; font-style:italic; }
  .legend .dist-row { display:flex; align-items:center; gap:6px; }
</style>
</head>
<body>
<div id="header">
  <div><h1>AD Privilege Map - __DOMAIN__</h1></div>
  <div class="meta">__TIMESTAMP__ &middot; __NODECOUNT__ Nodes &middot; __EDGECOUNT__ Edges &middot; __ROUNDS__ Runden</div>
</div>

<div id="toolbar">
  <div class="grp">
    <label>Anzeige:
      <select id="display-mode">
        <option value="depth" selected>Auswahl + Nachbarn</option>
        <option value="all">Alle Nodes</option>
        <option value="attack-surface">Tier-0-Risiko (Distanz)</option>
        <option value="owned-cone">Owned-Cone (Selektion)</option>
      </select>
    </label>
    <label>Tiefe:
      <select id="depth-select">
        <option value="1">1</option>
        <option value="2" selected>2</option>
        <option value="3">3</option>
        <option value="4">4</option>
        <option value="6">6</option>
        <option value="999">Alle</option>
      </select>
    </label>
    <label>Max-Distanz:
      <select id="max-dist-select">
        <option value="1">1</option>
        <option value="2">2</option>
        <option value="3" selected>3</option>
        <option value="4">4</option>
        <option value="6">6</option>
        <option value="999">alle</option>
      </select>
    </label>
    <button id="toggle-paths-btn" type="button" style="padding:4px 10px; cursor:pointer;">Top-Pfade</button>
    <button id="refit-btn" type="button" style="padding:4px 10px; cursor:pointer;" title="Ansicht auf sichtbare Nodes zuruecksetzen">Refit</button>
  </div>
  <div class="grp">
    <label>Layout:
      <select id="layout-select">
        <option value="physics">Physics</option>
        <option value="hierarchical">Hierarchisch (Tier-0 oben)</option>
      </select>
    </label>
  </div>
  <div class="grp">
    <label><input type="checkbox" id="f-tier0"> Nur Tier-0</label>
    <label><input type="checkbox" id="f-active"> Nur aktive User</label>
    <label><input type="checkbox" id="f-hidecomp"> Computer aus</label>
    <label><input type="checkbox" id="f-hidefsp"> Foreign SPs aus</label>
    <label><input type="checkbox" id="f-hidelateral"> Laterale Gruppen aus</label>
    <label><input type="checkbox" id="f-hidelatmem"> Lat. Members aus</label>
    <label><input type="checkbox" id="f-hidelatpar"> Lat. Parents aus</label>
    <label><input type="checkbox" id="f-hidekerb"> Kerberos-Edges aus</label>
    <label><input type="checkbox" id="f-hideacl"> ACL-Edges aus</label>
    <label>Min. Memberships pro User: <input type="number" id="f-minmem" value="0" min="0" max="50" style="width:50px;"></label>
  </div>
  <div class="grp">
    <label>Suche: <input type="text" id="search" placeholder="Name..." style="width:200px;"></label>
  </div>
</div>

<div id="network"></div>

<div class="legend">
  <div><span class="swatch" style="background:#dc2626"></span>Tier-0 Root-Gruppe</div>
  <div><span class="swatch" style="background:#ea580c"></span>Gruppe (AdminCount=1)</div>
  <div><span class="swatch" style="background:#f59e0b"></span>Gruppe (normal)</div>
  <div><span class="swatch" style="background:#fcd34d"></span>Gruppe (lateral, nur via A2)</div>
  <div><span class="swatch" style="background:#fef3c7"></span>Gruppe (Member einer lat. Gruppe)</div>
  <div><span class="swatch" style="background:#d9f99d"></span>Gruppe (Parent einer lat. Gruppe)</div>
  <div><span class="swatch" style="background:#b91c1c"></span>User (AdminCount=1)</div>
  <div><span class="swatch" style="background:#7c2d12"></span>SDProp-Waise</div>
  <div><span class="swatch" style="background:#3b82f6"></span>User (aktiv)</div>
  <div><span class="swatch" style="background:#bfdbfe"></span>User (Member einer lat. Gruppe)</div>
  <div><span class="swatch" style="background:#9ca3af"></span>User (deaktiviert)</div>
  <div><span class="swatch" style="background:#10b981"></span>Computer</div>
  <div><span class="swatch" style="background:#bbf7d0"></span>Computer (lat. Member)</div>
  <div><span class="swatch" style="background:#a855f7"></span>Foreign SP</div>
  <div><span class="swatch" style="background:#64748b"></span>OU</div>
  <div class="hint">Pfeilrichtung A -&gt; B = "A ist Mitglied von B"<br>Klick auf Node oder Eingabe im Suchfeld = Pfad markieren<br><br>Edge-Farben:<br><span style="color:#555;font-weight:bold">grau</span> = Mitgliedschaft<br><span style="color:#7c3aed;font-weight:bold">lila</span> = Kerberos-Delegation<br><span style="color:#f97316;font-weight:bold">orange</span> = ACL-Recht</div>
  <div class="hint" id="dist-legend" style="display:none">
    <strong>Tier-0-Distanz:</strong><br>
    <div class="dist-row"><span class="swatch" style="background:#fff;border:3px solid #dc2626"></span>1 Hop bis Tier-0</div>
    <div class="dist-row"><span class="swatch" style="background:#fff;border:3px solid #ea580c"></span>2 Hops</div>
    <div class="dist-row"><span class="swatch" style="background:#fff;border:3px solid #ca8a04"></span>3 Hops</div>
    <div class="dist-row"><span class="swatch" style="background:#fff;border:3px solid #65a30d"></span>4+ Hops</div>
  </div>
</div>

<div id="paths-panel" class="hidden">
  <div class="head">
    <span>Top Attack-Pfade zu Tier-0</span>
    <button id="paths-close" title="Schliessen">&times;</button>
  </div>
  <div class="body" id="paths-body"></div>
</div>

<div id="stats"></div>

<div id="loading">
  <div>Map wird berechnet...</div>
  <progress id="loading-progress" value="0" max="100"></progress>
  <div id="loading-text">Initialisierung...</div>
</div>

<script>
  const allNodesData = __NODESJSON__;
  const allEdgesData = __EDGESJSON__;
  // Edges mit IDs versehen (Voraussetzung fuer DataSet.update)
  allEdgesData.forEach((e, idx) => { e.id = 'e' + idx; });

  // Adjacency-Listen einmalig vorberechnen (fuer BFS in beide Richtungen)
  const adjOut = {};
  const adjIn  = {};
  allEdgesData.forEach(e => {
    if (!adjOut[e.from]) adjOut[e.from] = [];
    if (!adjIn[e.to])    adjIn[e.to]    = [];
    adjOut[e.from].push(e.to);
    adjIn[e.to].push(e.from);
  });

  // Anzahl ausgehender Edges pro User-Node (= Group-Memberships)
  const userMembershipCount = {};
  allEdgesData.forEach(e => {
    userMembershipCount[e.from] = (userMembershipCount[e.from] || 0) + 1;
  });

  // Original-Farbe pro Node fuer Reset cachen
  allNodesData.forEach(n => {
    n._origColor = (typeof n.color === 'string') ? n.color : ((n.color && n.color.background) || '#888');
  });

  const state = {
    displayMode: 'depth',
    depth:       2,
    maxDist:     3,
    tier0Only:   false,
    activeOnly:  false,
    hideComps:   false,
    hideFsp:     false,
    hideLateral: false,
    hideLatMem:  false,
    hideLatPar:  false,
    hideKerb:    false,
    hideAcl:     false,
    minMembers:  0
  };

  let highlightId = null;  // ID des aktuell markierten Nodes fuer Pfad-Hervorhebung

  const HIGHLIGHT_COLOR = '#dc2626';   // rot fuer Pfad
  const DIMMED_BG       = '#e5e7eb';   // hellgrau fuer ausgeblendete Nodes
  const DIMMED_FONT     = '#9ca3af';

  // Outline-Farben nach Distanz zu Tier-0 (1=naechste, 4+=ferner)
  const DIST_COLORS = { 1: '#dc2626', 2: '#ea580c', 3: '#ca8a04', 4: '#65a30d' };
  function distColor(d) { return DIST_COLORS[d] || DIST_COLORS[4]; }

  function isTier0(node) {
    if (node.nodeType === 'Group') return node.nodeIsRoot || node.nodeAdminCount;
    if (node.nodeType === 'User')  return node.nodeAdminCount || node.nodeIsOrphan;
    return false;
  }

  // ---- Attack-Path-Precomputation ----------------------------------------
  // distanceToTier0[id] = Anzahl Hops in Outbound-Richtung bis zu einem Tier-0-Node.
  // Wird per Multi-Source-BFS von allen Tier-0-Nodes in Inbound-Richtung berechnet.
  const tier0Ids = new Set();
  allNodesData.forEach(n => { if (isTier0(n)) tier0Ids.add(n.id); });

  const distanceToTier0 = {};
  (function computeDistances() {
    const queue = [];
    tier0Ids.forEach(id => { distanceToTier0[id] = 0; queue.push(id); });
    while (queue.length) {
      const cur = queue.shift();
      const d   = distanceToTier0[cur];
      (adjIn[cur] || []).forEach(n => {
        if (distanceToTier0[n] === undefined) {
          distanceToTier0[n] = d + 1;
          queue.push(n);
        }
      });
    }
  })();

  // Set aller Nodes, die auf einem kuerzesten Pfad von startId zu *einem* Tier-0-Node liegen.
  // Voraussetzung: distanceToTier0[startId] ist definiert.
  function shortestPathsToTier0(startId) {
    if (distanceToTier0[startId] === undefined) return new Set();
    const result = new Set([startId]);
    const queue = [startId];
    while (queue.length) {
      const cur     = queue.shift();
      const curDist = distanceToTier0[cur];
      if (curDist === 0) continue;
      (adjOut[cur] || []).forEach(n => {
        if (distanceToTier0[n] === curDist - 1 && !result.has(n)) {
          result.add(n);
          queue.push(n);
        }
      });
    }
    return result;
  }

  // Outbound transitive Huelle ab startId (= alles, was startId direkt/indirekt uebernehmen kann).
  function ownedConeFrom(startId) {
    const set = new Set([startId]);
    const queue = [startId];
    while (queue.length) {
      const cur = queue.shift();
      (adjOut[cur] || []).forEach(n => {
        if (!set.has(n)) { set.add(n); queue.push(n); }
      });
    }
    return set;
  }

  // Top-N nicht-Tier-0-Nodes nach Distanz aufsteigend (innerhalb maxDist).
  function topAttackPaths(n, maxDist) {
    return allNodesData
      .filter(node => !tier0Ids.has(node.id) && distanceToTier0[node.id] !== undefined && distanceToTier0[node.id] <= maxDist)
      .sort((a, b) => {
        const da = distanceToTier0[a.id];
        const db = distanceToTier0[b.id];
        if (da !== db) return da - db;
        return (a.label || '').localeCompare(b.label || '');
      })
      .slice(0, n);
  }

  function nodeVisible(node) {
    if (state.tier0Only && !isTier0(node)) return false;
    if (state.activeOnly && node.nodeType === 'User' && node.nodeEnabled === false) return false;
    if (state.hideComps && node.nodeType === 'Computer') return false;
    if (state.hideFsp && node.nodeType === 'ForeignSecurityPrincipal') return false;
    if (state.hideLateral && node.nodeLateral) return false;
    if (state.hideLatMem && node.nodeLatMember) return false;
    if (state.hideLatPar && node.nodeLatParent) return false;
    if (state.minMembers > 0 && node.nodeType === 'User') {
      const c = userMembershipCount[node.id] || 0;
      if (c < state.minMembers) return false;
    }
    return true;
  }

  // BFS in beide Richtungen ab startId. Liefert Set aller erreichbaren, sichtbaren Node-IDs.
  function findReachable(startId, visibleSet) {
    const set = new Set([startId]);
    let queue = [startId];
    while (queue.length) {
      const cur = queue.shift();
      (adjOut[cur] || []).forEach(n => {
        if (!set.has(n) && visibleSet.has(n)) { set.add(n); queue.push(n); }
      });
    }
    queue = [startId];
    while (queue.length) {
      const cur = queue.shift();
      (adjIn[cur] || []).forEach(n => {
        if (!set.has(n) && visibleSet.has(n)) { set.add(n); queue.push(n); }
      });
    }
    return set;
  }

  // BFS mit Tiefen-Limit (beide Richtungen). Fuer Display-Mode "Auswahl + Nachbarn".
  function findReachableWithDepth(startId, maxDepth) {
    const result = new Set([startId]);
    if (maxDepth <= 0) return result;
    let queue = [startId];
    for (let d = 0; d < maxDepth; d++) {
      const nextQueue = [];
      queue.forEach(cur => {
        (adjOut[cur] || []).forEach(n => {
          if (!result.has(n)) { result.add(n); nextQueue.push(n); }
        });
        (adjIn[cur] || []).forEach(n => {
          if (!result.has(n)) { result.add(n); nextQueue.push(n); }
        });
      });
      queue = nextQueue;
      if (queue.length === 0) break;
    }
    return result;
  }

  const NORMAL_EDGE = '#555';

  const physicsOptions = {
    layout: { hierarchical: { enabled: false } },
    physics: {
      enabled: true,
      solver: 'barnesHut',
      barnesHut: {
        gravitationalConstant: -150000,
        centralGravity: 0.005,
        springLength: 500,
        springConstant: 0.02,
        damping: 0.4,
        avoidOverlap: 1
      },
      stabilization: {
        enabled: true,
        iterations: 5000,
        updateInterval: 50,
        onlyDynamicEdges: false,
        fit: true
      },
      minVelocity: 0.75
    },
    edges: { arrows: { to: { enabled: true, scaleFactor: 1.2 } }, color: NORMAL_EDGE, smooth: { type: 'continuous' } },
    nodes: { font: { size: 12, face: 'Segoe UI' }, borderWidth: 1, size: 14 },
    interaction: { hover: true, tooltipDelay: 150, navigationButtons: true, keyboard: true }
  };

  const hierarchicalOptions = {
    layout: { hierarchical: { enabled: true, direction: 'DU', sortMethod: 'directed', nodeSpacing: 200, levelSeparation: 220, treeSpacing: 300, blockShifting: true, edgeMinimization: true } },
    physics: { enabled: false },
    edges: { arrows: { to: { enabled: true, scaleFactor: 1.2 } }, color: NORMAL_EDGE, smooth: { type: 'cubicBezier', forceDirection: 'vertical', roundness: 0.4 } },
    nodes: { font: { size: 12, face: 'Segoe UI' }, borderWidth: 1, size: 14 },
    interaction: { hover: true, tooltipDelay: 150, navigationButtons: true, keyboard: true }
  };

  // Persistente DataSets: Filter/Highlight nutzen update() statt setData(),
  // damit Knotenpositionen erhalten bleiben und nichts mehr wackelt.
  const nodesDS = new vis.DataSet(allNodesData);
  const edgesDS = new vis.DataSet(allEdgesData);

  const container = document.getElementById('network');
  const net = new vis.Network(container, { nodes: nodesDS, edges: edgesDS }, physicsOptions);

  // Loading-Overlay-Steuerung
  const loadingDiv  = document.getElementById('loading');
  const loadingProg = document.getElementById('loading-progress');
  const loadingTxt  = document.getElementById('loading-text');
  function showLoading(text) {
    loadingDiv.style.display = 'flex';
    loadingTxt.textContent = text || 'Map wird berechnet...';
    loadingProg.value = 0;
  }
  function hideLoading() { loadingDiv.style.display = 'none'; }

  net.on('stabilizationProgress', params => {
    const percent = Math.round((params.iterations / params.total) * 100);
    loadingProg.value = percent;
    loadingTxt.textContent = 'Stabilisierung: ' + percent + '% (' + params.iterations + ' / ' + params.total + ')';
  });
  // ---- Layout-State -------------------------------------------------------
  // originalPositions wird nach der ersten Stabilisierung eingefroren und ist
  // die "freie" Layout-Referenz fuer depth/all-Modus. Wird beim Wechsel in
  // strukturierte Modi (attack-surface, owned-cone) durch programmatische
  // Layouts ersetzt und ggf. wieder restored.
  let originalPositions = null;
  let lastLayoutKey     = null;
  let lastVisibleSize   = 0;
  let lastZoomThreshold = true;  // sind Edge-Labels aktuell sichtbar?
  let currentVisible    = new Set();   // wird von render() gepflegt
  const LABEL_ZOOM_THRESHOLD = 0.6;

  net.on('stabilizationIterationsDone', () => {
    net.setOptions({ physics: { enabled: false } });
    if (!originalPositions) {
      originalPositions = net.getPositions();
    }
    hideLoading();
  });

  // Nach Drag-End in freien Modi die Position als "neue Wahrheit" merken
  net.on('dragEnd', params => {
    if (!originalPositions || !params.nodes || params.nodes.length === 0) return;
    if (currentLayoutKey() !== 'free') return;
    const pos = net.getPositions(params.nodes);
    params.nodes.forEach(id => { if (pos[id]) originalPositions[id] = pos[id]; });
  });

  net.on('zoom', () => applyLabelMask());

  function currentLayoutKey() {
    if (state.displayMode === 'attack-surface') {
      return 'attack:' + state.maxDist + ':' + (highlightId || '');
    }
    if (state.displayMode === 'owned-cone' && highlightId) {
      return 'cone:' + highlightId;
    }
    return 'free';
  }

  // ---- Programmatische Layouts ------------------------------------------
  function restoreOriginalPositions() {
    if (!originalPositions) return;
    const updates = [];
    for (const id in originalPositions) {
      const p = originalPositions[id];
      updates.push({ id: id, x: p.x, y: p.y });
    }
    nodesDS.update(updates);
  }

  // Layered Layout: Knoten werden nach layerFn(id) in horizontale Reihen
  // gruppiert. Layer 0 oben, hoehere Layer weiter unten. Lange Reihen
  // werden in mehrere Sub-Rows umgebrochen.
  function applyLayeredLayout(visibleIds, layerFn) {
    const buckets = {};
    visibleIds.forEach(id => {
      const l = layerFn(id);
      if (l === undefined || l === null) return;
      if (!buckets[l]) buckets[l] = [];
      buckets[l].push(id);
    });
    const layers = Object.keys(buckets).map(Number).sort((a, b) => a - b);
    if (layers.length === 0) return;

    const X_STEP    = 200;
    const Y_STEP    = 200;
    const SUB_Y    = 70;
    const MAX_COLS = 25;
    const yMid     = ((layers.length - 1) * Y_STEP) / 2;
    const updates  = [];

    layers.forEach((l, lIdx) => {
      const items = buckets[l].slice().sort();
      const yBase = lIdx * Y_STEP - yMid;
      const rows  = Math.ceil(items.length / MAX_COLS);
      items.forEach((id, i) => {
        const row    = Math.floor(i / MAX_COLS);
        const col    = i % MAX_COLS;
        const inRow  = Math.min(MAX_COLS, items.length - row * MAX_COLS);
        const x      = (col - (inRow - 1) / 2) * X_STEP;
        const yExtra = (rows > 1) ? (row - (rows - 1) / 2) * SUB_Y : 0;
        updates.push({ id: id, x: x, y: yBase + yExtra });
      });
    });
    nodesDS.update(updates);
  }

  // Radial Layout ab centerId entlang outbound-BFS. Konzentrische Ringe pro
  // BFS-Distanz, gleichmaessig auf dem Ring verteilt, alternierende Phase
  // gegen "Speichen-Effekt" benachbarter Layer.
  function applyRadialLayout(centerId, visibleIds, direction) {
    if (!visibleIds.has(centerId)) return;
    const adj = (direction === 'inbound') ? adjIn : adjOut;
    const layer = { [centerId]: 0 };
    const queue = [centerId];
    while (queue.length) {
      const cur = queue.shift();
      (adj[cur] || []).forEach(n => {
        if (visibleIds.has(n) && layer[n] === undefined) {
          layer[n] = layer[cur] + 1;
          queue.push(n);
        }
      });
    }

    const buckets = {};
    visibleIds.forEach(id => {
      const l = (layer[id] !== undefined) ? layer[id] : -1;   // disconnected: outer ring
      if (!buckets[l]) buckets[l] = [];
      buckets[l].push(id);
    });

    const RADIUS_STEP = 280;
    const updates = [];
    const ringKeys = Object.keys(buckets).map(Number).sort((a, b) => a - b);
    const disconnectedRing = ringKeys.includes(-1) ? Math.max(...ringKeys.filter(k => k >= 0), 0) + 1 : null;

    ringKeys.forEach(l => {
      const items = buckets[l].slice().sort();
      if (l === 0) {
        updates.push({ id: items[0], x: 0, y: 0 });
        return;
      }
      const ringIdx  = (l === -1) ? disconnectedRing : l;
      const r        = ringIdx * RADIUS_STEP;
      const offset   = (ringIdx % 2) ? Math.PI / Math.max(1, items.length) : 0;
      items.forEach((id, idx) => {
        const angle = (idx / items.length) * 2 * Math.PI + offset;
        updates.push({ id: id, x: r * Math.cos(angle), y: r * Math.sin(angle) });
      });
    });
    nodesDS.update(updates);
  }

  function applyLayoutIfKeyChanged(visibleSet) {
    const key = currentLayoutKey();
    if (key === lastLayoutKey) return false;
    lastLayoutKey = key;

    if (state.displayMode === 'attack-surface' && originalPositions) {
      applyLayeredLayout(visibleSet, id => distanceToTier0[id]);
      return true;
    }
    if (state.displayMode === 'owned-cone' && highlightId && originalPositions) {
      applyRadialLayout(highlightId, visibleSet, 'outbound');
      return true;
    }
    if (originalPositions) {
      restoreOriginalPositions();
      return true;
    }
    return false;
  }

  // ---- Smart-Fit + Adaptive Focus ----------------------------------------
  function smartFitVisible(visibleSet, force) {
    if (!originalPositions) return;          // noch nicht stabilisiert
    if (visibleSet.size === 0) return;
    const sizeDiff = Math.abs(visibleSet.size - lastVisibleSize);
    const sizeChangeRatio = sizeDiff / Math.max(1, allNodesData.length);
    const triggered = force || sizeChangeRatio > 0.3;
    lastVisibleSize = visibleSet.size;
    if (!triggered) return;
    net.fit({
      nodes: [...visibleSet],
      animation: { duration: 600, easingFunction: 'easeInOutQuad' }
    });
    // Cap: bei sehr wenigen Knoten nach dem Fit den Zoom hart begrenzen,
    // damit Einzelknoten nicht den ganzen Viewport fuellen.
    if (visibleSet.size <= 3) {
      setTimeout(() => {
        if (net.getScale() > 1.5) {
          const vp = net.getViewPosition();
          net.moveTo({ scale: 1.5, position: vp, animation: { duration: 200 } });
        }
      }, 650);
    }
  }

  function focusAdaptive(id, visibleSet) {
    const neighbors = ((adjOut[id] || []).filter(n => visibleSet.has(n)).length +
                       (adjIn[id]  || []).filter(n => visibleSet.has(n)).length);
    let scale;
    if (visibleSet.size <= 5)        scale = 1.0;
    else if (neighbors === 0)        scale = 1.8;
    else if (neighbors <= 3)         scale = 1.4;
    else if (neighbors <= 10)        scale = 1.0;
    else                             scale = 0.7;
    net.focus(id, { scale: scale, animation: { duration: 400, easingFunction: 'easeInOutQuad' } });
  }

  // ---- Importance-Sizing --------------------------------------------------
  function importanceSize(node, mode) {
    if (node.shape === 'box') return undefined;   // boxes auto-sizen via Label
    let metric;
    if (mode === 'attack-surface')      metric = (adjIn[node.id]  || []).length;
    else if (mode === 'owned-cone')     metric = (adjOut[node.id] || []).length;
    else                                metric = ((adjIn[node.id] || []).length + (adjOut[node.id] || []).length);
    const base = 10 + Math.min(18, Math.log2(metric + 1) * 4);
    return Math.round((isTier0(node) ? base + 4 : base));
  }

  // ---- Edge-Label-Zoom-Mask ----------------------------------------------
  // Re-applied bei jedem Zoom und nach render(). Wenn der Zoom unter
  // LABEL_ZOOM_THRESHOLD faellt, werden Labels geleert.
  function applyLabelMask() {
    if (!originalPositions) return;
    const z = net.getScale();
    const show = z >= LABEL_ZOOM_THRESHOLD;
    if (show === lastZoomThreshold) return;
    lastZoomThreshold = show;
    const updates = [];
    allEdgesData.forEach(e => {
      const cur = edgesDS.get(e.id);
      if (!cur || cur.hidden) return;
      const intended = e._intendedLabel || '';
      const desired  = show ? intended : '';
      if (cur.label !== desired) updates.push({ id: e.id, label: desired });
    });
    if (updates.length) edgesDS.update(updates);
  }

  function render() {
    // Schritt 1: Basis-Sichtbarkeit nach Display-Modus
    let baseSet;
    let attackPathSet = null;     // Pfad-Subset im attack-surface-Modus mit Selektion
    let ownedConeSet  = null;     // Outbound-Huelle im owned-cone-Modus
    let distColored   = false;    // Faerbung nach Distanz aktiv

    if (state.displayMode === 'depth') {
      if (highlightId !== null) {
        baseSet = findReachableWithDepth(highlightId, state.depth);
      } else {
        baseSet = new Set();
        allNodesData.forEach(n => { if (isTier0(n)) baseSet.add(n.id); });
      }
    } else if (state.displayMode === 'attack-surface') {
      if (highlightId !== null && distanceToTier0[highlightId] !== undefined) {
        attackPathSet = shortestPathsToTier0(highlightId);
        baseSet = new Set(attackPathSet);
      } else {
        baseSet = new Set();
        allNodesData.forEach(n => {
          const d = distanceToTier0[n.id];
          if (d !== undefined && d <= state.maxDist) baseSet.add(n.id);
        });
      }
      distColored = (attackPathSet === null);
    } else if (state.displayMode === 'owned-cone') {
      if (highlightId !== null) {
        ownedConeSet = ownedConeFrom(highlightId);
        baseSet = new Set(ownedConeSet);
      } else {
        // Ohne Selektion zeigen wir nur Tier-0 als Anker und einen Hinweis im stats-Text.
        baseSet = new Set();
        allNodesData.forEach(n => { if (isTier0(n)) baseSet.add(n.id); });
      }
    } else {
      baseSet = new Set(allNodesData.map(n => n.id));
    }

    const visibleSet = new Set();
    allNodesData.forEach(n => {
      if (baseSet.has(n.id) && nodeVisible(n)) visibleSet.add(n.id);
    });
    currentVisible = visibleSet;

    // pathSet (rote Hervorhebung) im "all"-Modus mit Selektion
    const pathSet = (state.displayMode === 'all' && highlightId !== null && visibleSet.has(highlightId))
      ? findReachable(highlightId, visibleSet)
      : null;

    // Layout per Modus setzen (programmatisch fuer attack-surface / owned-cone,
    // sonst Original-Positionen). Liefert true, wenn sich der Layout-Key
    // geaendert hat -> Smart-Fit am Ende auf jeden Fall ausloesen.
    const layoutChanged = applyLayoutIfKeyChanged(visibleSet);

    const nodeUpdates = allNodesData.map(n => {
      const isVis = visibleSet.has(n.id);
      const u = { id: n.id, hidden: !isVis };
      if (isVis) {
        const sz = importanceSize(n, state.displayMode);
        if (sz !== undefined) u.size = sz;
        if (pathSet) {
          // 'all'-Modus mit Pfad
          if (pathSet.has(n.id)) {
            u.color = { background: n._origColor, border: HIGHLIGHT_COLOR };
            u.borderWidth = (n.id === highlightId) ? 6 : 3;
            u.font = { color: '#000', size: 12, face: 'Segoe UI' };
          } else {
            u.color = { background: DIMMED_BG, border: DIMMED_BG };
            u.borderWidth = 1;
            u.font = { color: DIMMED_FONT, size: 12, face: 'Segoe UI' };
          }
        } else if (attackPathSet) {
          // attack-surface mit Selektion: kuerzester Pfad zu Tier-0 rot
          u.color = { background: n._origColor, border: HIGHLIGHT_COLOR };
          u.borderWidth = (n.id === highlightId) ? 6 : 3;
          u.font = { color: '#000', size: 12, face: 'Segoe UI' };
        } else if (distColored) {
          // attack-surface ohne Selektion: Outline nach Distanz
          const d = distanceToTier0[n.id];
          const border = (d === 0) ? HIGHLIGHT_COLOR : distColor(d);
          u.color = { background: n._origColor, border: border };
          u.borderWidth = (d === 0) ? 3 : 4;
          u.font = { color: '#000', size: 12, face: 'Segoe UI' };
        } else if (ownedConeSet) {
          // owned-cone: Highlight-Node fett, Rest mit oranger Outline (markiert "in Besitz")
          if (n.id === highlightId) {
            u.color = { background: n._origColor, border: HIGHLIGHT_COLOR };
            u.borderWidth = 6;
          } else {
            u.color = { background: n._origColor, border: '#ea580c' };
            u.borderWidth = 3;
          }
          u.font = { color: '#000', size: 12, face: 'Segoe UI' };
        } else if (state.displayMode === 'depth' && n.id === highlightId) {
          u.color = { background: n._origColor, border: HIGHLIGHT_COLOR };
          u.borderWidth = 6;
          u.font = { color: '#000', size: 12, face: 'Segoe UI' };
        } else {
          u.color = n._origColor;
          u.borderWidth = 1;
          u.font = { color: '#000', size: 12, face: 'Segoe UI' };
        }
      }
      return u;
    });

    // Labels werden bei niedrigem Zoom maskiert. labelShown spiegelt den
    // aktuellen Wert von lastZoomThreshold; intended label landet auf
    // e._intendedLabel, damit applyLabelMask sie spaeter ohne Re-render
    // re-applien kann.
    const labelShown = lastZoomThreshold;

    const edgeUpdates = allEdgesData.map(e => {
      const isKerb = (e.edgeType === 'kerberos-constrained' || e.edgeType === 'kerberos-rbcd');
      const isAcl  = (e.edgeType === 'acl-right');
      let typeAllowed = true;
      if (state.hideKerb && isKerb) typeAllowed = false;
      if (state.hideAcl  && isAcl)  typeAllowed = false;

      const isVis = typeAllowed && visibleSet.has(e.from) && visibleSet.has(e.to);
      const u = { id: e.id, hidden: !isVis };
      let intended = '';

      if (isVis) {
        let baseColor = NORMAL_EDGE;
        let baseWidth = 1;
        if (isKerb)     { baseColor = '#7c3aed'; baseWidth = 2; }
        else if (isAcl) { baseColor = '#f97316'; baseWidth = 2; }

        if (pathSet) {
          if (pathSet.has(e.from) && pathSet.has(e.to)) {
            u.color = { color: HIGHLIGHT_COLOR, highlight: HIGHLIGHT_COLOR };
            u.width = 3;
          } else {
            u.color = { color: DIMMED_BG, opacity: 0.2 };
            u.width = 1;
          }
        } else if (attackPathSet) {
          const df = distanceToTier0[e.from];
          const dt = distanceToTier0[e.to];
          if (attackPathSet.has(e.from) && attackPathSet.has(e.to) && df === dt + 1) {
            u.color = { color: HIGHLIGHT_COLOR, highlight: HIGHLIGHT_COLOR };
            u.width = 3;
            if (e.label) intended = e.label;
          } else {
            u.color = { color: DIMMED_BG, opacity: 0.2 };
            u.width = 1;
          }
        } else if (distColored) {
          const df = distanceToTier0[e.from];
          const dt = distanceToTier0[e.to];
          if (df !== undefined && dt !== undefined && df === dt + 1) {
            u.color = { color: distColor(df) };
            u.width = 2;
          } else {
            u.color = { color: NORMAL_EDGE, opacity: 0.4 };
            u.width = 1;
          }
        } else {
          u.color = { color: baseColor };
          u.width = baseWidth;
          if (e.label) intended = e.label;
        }
      }
      e._intendedLabel = intended;
      u.label = labelShown ? intended : '';
      return u;
    });

    nodesDS.update(nodeUpdates);
    edgesDS.update(edgeUpdates);

    let statsText = 'Sichtbar: ' + visibleSet.size + ' Nodes';
    if (state.displayMode === 'depth') {
      if (highlightId !== null) {
        const hl = allNodesData.find(x => x.id === highlightId);
        const dLabel = (state.depth >= 999) ? 'alle' : state.depth;
        statsText += ' | Zentrum: ' + (hl ? hl.label : '?') + ' (Tiefe ' + dLabel + ')';
      } else {
        statsText += ' | Tier-0-Uebersicht - Knoten anklicken oder suchen, um zu erkunden';
      }
    } else if (state.displayMode === 'attack-surface') {
      if (attackPathSet && highlightId !== null) {
        const hl = allNodesData.find(x => x.id === highlightId);
        const d  = distanceToTier0[highlightId];
        statsText += ' | Pfad: ' + (hl ? hl.label : '?') + ' -> Tier-0 (' + d + ' Hops, ' + attackPathSet.size + ' Knoten im Layer)';
      } else {
        const mLabel = (state.maxDist >= 999) ? 'unbegrenzt' : ('<=' + state.maxDist);
        statsText += ' | Tier-0-Risiko, Max-Distanz ' + mLabel;
      }
    } else if (state.displayMode === 'owned-cone') {
      if (ownedConeSet && highlightId !== null) {
        const hl = allNodesData.find(x => x.id === highlightId);
        statsText += ' | Owned-Cone von ' + (hl ? hl.label : '?') + ' (' + ownedConeSet.size + ' uebernehmbar)';
      } else {
        statsText += ' | Owned-Cone: bitte einen Node anklicken oder suchen';
      }
    } else if (pathSet) {
      const hl = allNodesData.find(x => x.id === highlightId);
      statsText += ' | Pfad: ' + (hl ? hl.label : '?') + ' (' + pathSet.size + ' erreichbar)';
    }
    document.getElementById('stats').textContent = statsText;

    // Distanz-Legende nur im attack-surface-Modus ohne Selektion einblenden
    document.getElementById('dist-legend').style.display = (distColored ? '' : 'none');

    refreshTopPathsPanel();

    // Smart-Fit am Ende: bei Layout-Key-Wechsel immer, sonst nur wenn sich
    // das Visible-Set drastisch geaendert hat (>30% der Gesamtknoten).
    smartFitVisible(visibleSet, layoutChanged);
  }

  // ---- Top-Pfade-Panel ----------------------------------------------------
  function refreshTopPathsPanel() {
    const panel = document.getElementById('paths-panel');
    if (panel.classList.contains('hidden')) return;
    const body = document.getElementById('paths-body');
    const maxD = (state.displayMode === 'attack-surface' && state.maxDist < 999) ? state.maxDist : 6;
    const top  = topAttackPaths(20, maxD);
    if (top.length === 0) {
      body.innerHTML = '<div class="empty">Keine Pfade zu Tier-0 gefunden.</div>';
      return;
    }
    body.innerHTML = top.map(n => {
      const d = distanceToTier0[n.id];
      const dBucket = Math.min(d, 4);
      const safeLbl = (n.label || '').replace(/[<>&]/g, c => ({'<':'&lt;','>':'&gt;','&':'&amp;'}[c]));
      return '<div class="row" data-id="' + n.id + '">' +
             '<span class="lbl">' + safeLbl + '<span class="type">(' + n.nodeType + ')</span></span>' +
             '<span class="dist" data-d="' + dBucket + '">' + d + ' hops</span>' +
             '</div>';
    }).join('');
    body.querySelectorAll('.row').forEach(row => {
      row.addEventListener('click', () => {
        highlightId = row.getAttribute('data-id');
        const sel = document.getElementById('display-mode');
        if (sel.value !== 'attack-surface') {
          sel.value = 'attack-surface';
          state.displayMode = 'attack-surface';
        }
        render();
        focusAdaptive(highlightId, currentVisible);
      });
    });
  }

  render();

  document.getElementById('display-mode').addEventListener('change', e => { state.displayMode = e.target.value; render(); });
  document.getElementById('depth-select').addEventListener('change', e => {
    const v = parseInt(e.target.value, 10);
    state.depth = isNaN(v) ? 2 : v;
    render();
  });
  document.getElementById('max-dist-select').addEventListener('change', e => {
    const v = parseInt(e.target.value, 10);
    state.maxDist = isNaN(v) ? 3 : v;
    render();
  });
  document.getElementById('toggle-paths-btn').addEventListener('click', () => {
    const panel = document.getElementById('paths-panel');
    panel.classList.toggle('hidden');
    if (!panel.classList.contains('hidden')) refreshTopPathsPanel();
  });
  document.getElementById('paths-close').addEventListener('click', () => {
    document.getElementById('paths-panel').classList.add('hidden');
  });
  document.getElementById('refit-btn').addEventListener('click', () => {
    if (currentVisible.size > 0) {
      net.fit({ nodes: [...currentVisible], animation: { duration: 500, easingFunction: 'easeInOutQuad' } });
    } else {
      net.fit({ animation: { duration: 500 } });
    }
  });

  document.getElementById('f-tier0').addEventListener('change', e => { state.tier0Only = e.target.checked; render(); });
  document.getElementById('f-active').addEventListener('change', e => { state.activeOnly = e.target.checked; render(); });
  document.getElementById('f-hidecomp').addEventListener('change', e => { state.hideComps = e.target.checked; render(); });
  document.getElementById('f-hidefsp').addEventListener('change', e => { state.hideFsp = e.target.checked; render(); });
  document.getElementById('f-hidelateral').addEventListener('change', e => { state.hideLateral = e.target.checked; render(); });
  document.getElementById('f-hidelatmem').addEventListener('change', e => { state.hideLatMem = e.target.checked; render(); });
  document.getElementById('f-hidelatpar').addEventListener('change', e => { state.hideLatPar = e.target.checked; render(); });
  document.getElementById('f-hidekerb').addEventListener('change', e => { state.hideKerb = e.target.checked; render(); });
  document.getElementById('f-hideacl').addEventListener('change', e => { state.hideAcl = e.target.checked; render(); });
  document.getElementById('f-minmem').addEventListener('change', e => {
    const v = parseInt(e.target.value, 10);
    state.minMembers = isNaN(v) || v < 0 ? 0 : v;
    render();
  });

  document.getElementById('layout-select').addEventListener('change', e => {
    showLoading('Layout-Wechsel...');
    if (e.target.value === 'hierarchical') {
      net.setOptions(hierarchicalOptions);
      // Hierarchisches Layout hat keine Physics-Stabilization -> manuell fitten
      setTimeout(() => {
        net.fit({ animation: { duration: 400 } });
        hideLoading();
      }, 200);
    } else {
      // Zurueck zu Physics: re-enabled Stabilization
      net.setOptions(physicsOptions);
      // hideLoading wird durch stabilizationIterationsDone ausgeloest
    }
  });

  // Suche: erster Match wird markiert, alle erreichbaren Pfade hervorgehoben
  document.getElementById('search').addEventListener('input', e => {
    const q = e.target.value.trim().toLowerCase();
    if (!q) {
      highlightId = null;
      render();
      return;
    }
    const match = allNodesData.find(x => (x.label || '').toLowerCase().includes(q));
    if (match) {
      highlightId = match.id;
      render();
      focusAdaptive(match.id, currentVisible);
    } else {
      highlightId = null;
      render();
    }
  });
</script>
</body>
</html>
